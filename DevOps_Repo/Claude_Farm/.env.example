# Database
DATABASE_URL="postgresql://postgres:password@localhost:5433/farmconnect?schema=public"

# Redis (BullMQ + session cache)
REDIS_URL="redis://localhost:6380"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-in-production-min-32-chars-refresh"

# App
NODE_ENV="development"
PORT=3000
LOG_LEVEL="info"
CORS_ORIGIN="http://localhost:5173"

# Sentry
SENTRY_DSN=""

# Cloudflare R2 (photo storage)
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="farmconnect-photos"
CLOUDFLARE_R2_PUBLIC_URL="https://photos.farmconnect.co.za"

# Ozow (buyer payments)
OZOW_SITE_CODE=""
OZOW_PRIVATE_KEY=""
OZOW_API_KEY=""

# Stitch (farmer payouts)
STITCH_CLIENT_ID=""
STITCH_CLIENT_SECRET=""
STITCH_CLIENT_TOKEN=""
STITCH_WEBHOOK_SECRET=""

# Clickatell (WhatsApp + SMS)
CLICKATELL_API_KEY=""

# SendGrid (email)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@farmconnect.co.za"

# Frontend
VITE_API_URL="http://localhost:3000/api/v1"
