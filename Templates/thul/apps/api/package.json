{
  "name": "@shopflow/api",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "cd ../../packages/db && npx prisma migrate dev",
    "db:seed": "cd ../../packages/db && npx tsx prisma/seed.ts",
    "db:generate": "cd ../../packages/db && npx prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "@shopflow/db": "*",
    "@trpc/server": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.4.2",
    "multer": "^2.1.1",
    "resend": "^4.1.2",
    "stripe": "^17.4.0",
    "superjson": "^2.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
